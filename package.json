{
  "name": "audio-to-haptics",
  "private": false,
  "version": "0.0.3",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./react": {
      "import": "./lib/react.js",
      "types": "./lib/react.d.ts"
    }
  },
  "keywords": [
    "haptics",
    "vibration",
    "audio",
    "audio-analysis",
    "waveform",
    "vibration-api",
    "web-audio",
    "web-audio-api",
    "haptic-feedback",
    "haptic-pattern",
    "audio-reactive",
    "mobile",
    "android",
    "react",
    "react-hook",
    "typescript",
    "music",
    "beat-detection",
    "pulse-width-modulation",
    "pwm",
    "amplitude",
    "sound",
    "frequency",
    "media",
    "video",
    "sync",
    "realtime",
    "requestanimationframe",
    "navigator-vibrate"
  ],
  "files": [
    "lib"
  ],
  "peerDependencies": {
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "react": ">=19",
    "react-dom": "^19.2.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  }
}
